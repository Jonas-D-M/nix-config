{
  "allowPty": true,
  "enableWeakerNestedSandbox": true,
  "network": {
    "allowedDomains": [
      "*.anthropic.com",
      "*.claude.ai",
      "api.github.com",
      "github.com",
      "*.githubusercontent.com",
      "*.npmjs.org",
      "registry.npmjs.org"
    ],
    "deniedDomains": [],
    "allowLocalBinding": true
  },
  "filesystem": {
    "denyRead": ["~/.ssh", "~/.gnupg", "~/.sops"],
    "allowRead": ["~/.colima", "~/.docker"],
    "allowWrite": [".", "/tmp", "/private/tmp", "/var/folders"],
    "denyWrite": [".env", ".env.local", ".env.production"]
  }
}
